---
import { client } from '../data/client';

const whatsappUrl = `https://wa.me/${client.phoneForTel.replace('+', '')}?text=Halo%20Jayatama%20Bore%20Pile,%20saya%20ingin%20tanya%20mengenai%20jasa%20bore%20pile.`;
---

<a
  href={whatsappUrl}
  target="_blank"
  rel="noopener noreferrer"
  class="fixed bottom-6 right-6 z-[999] flex items-center gap-2 rounded-full bg-[#25D366] px-4 py-3 text-white shadow-lg transition-transform hover:scale-105 active:scale-95 sm:bottom-8 sm:right-8"
  aria-label="Hubungi kami di WhatsApp"
>
  <img
    src="https://upload.wikimedia.org/wikipedia/commons/6/6b/WhatsApp.svg"
    alt="WhatsApp Icon"
    class="size-6 sm:size-7"
    loading="lazy"
  />
  <span class="font-bold text-sm sm:text-base">Hubungi Kami</span>
</a>
