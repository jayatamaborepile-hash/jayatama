---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Banner from '../../components/Banner.astro';
import { brand } from '../../config/brand';
import { client } from '../../data/client';
---

<BaseLayout
  title="Kontak"
  description={`Hubungi ${brand.name}. Minta penawaran gratis atau ajukan pertanyaan kepada kami.`}
  schema={{
    '@context': 'https://schema.org',
    '@type': 'ContactPage',
    name: `Hubungi ${brand.name}`,
    description: `Halaman kontak ${brand.name} untuk permintaan penawaran dan konsultasi jasa bore pile.`,
    mainEntity: {
      '@type': 'LocalBusiness',
      name: brand.name,
      telephone: client.phoneForTel,
      email: client.email,
    }
  }}
>
  <Header slot="header" />

  <Banner title="Hubungi Kami" />

  <section class="py-section">
    <div class="mx-auto grid max-w-site grid-cols-1 gap-10 px-4 sm:px-6 lg:grid-cols-5 lg:gap-14">

      <!-- Form -->
      <div class="lg:col-span-3">
        <h2 class="font-heading text-h2 font-bold uppercase text-text">Kirim Pesan</h2>
        <p class="mt-2 mb-8 text-text-muted">
          Isi formulir di bawah ini dan kami akan segera menghubungi Anda.
        </p>

        <form
          name="contact"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          action="/contact/success"
          class="flex flex-col gap-5"
        >
          <input type="hidden" name="form-name" value="contact" />
          <p class="hidden" aria-hidden="true">
            <label>Leave this empty: <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
          </p>

          <label class="flex flex-col gap-1.5">
            <span class="text-sm font-medium text-text">Nama Lengkap <span class="text-accent" aria-hidden="true">*</span></span>
            <input
              type="text"
              name="name"
              required
              autocomplete="name"
              class="min-h-[44px] rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
            />
          </label>

          <label class="flex flex-col gap-1.5">
            <span class="text-sm font-medium text-text">Email <span class="text-accent" aria-hidden="true">*</span></span>
            <input
              type="email"
              name="email"
              required
              autocomplete="email"
              class="min-h-[44px] rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
            />
          </label>

          <label class="flex flex-col gap-1.5">
            <span class="text-sm font-medium text-text">Nomor HP/WhatsApp <span class="text-accent" aria-hidden="true">*</span></span>
            <input
              type="tel"
              name="phone"
              required
              autocomplete="tel"
              inputmode="tel"
              class="min-h-[44px] rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
            />
          </label>

          <label class="flex flex-col gap-1.5">
            <span class="text-sm font-medium text-text">Alamat Proyek (Kecamatan)</span>
            <input
              type="text"
              name="address"
              class="min-h-[44px] rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
            />
          </label>

          <label class="flex flex-col gap-1.5">
            <span class="text-sm font-medium text-text">Pesan / Kebutuhan <span class="text-accent" aria-hidden="true">*</span></span>
            <textarea
              name="message"
              rows="5"
              required
              placeholder="Contoh: Butuh bore pile untuk rumah 2 lantai, area gang sempit."
              class="min-h-[120px] rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 resize-y"
            ></textarea>
          </label>

          <button
            type="submit"
            class="mt-2 inline-flex min-h-[44px] cursor-pointer items-center justify-center self-start rounded-md bg-accent px-8 py-3 text-base font-bold text-accent-fg shadow-sm transition-opacity hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
          >
            Kirim Pesan
          </button>
        </form>
      </div>

      <!-- Contact info sidebar -->
      <aside class="space-y-8 lg:col-span-2">
        <div>
          <h3 class="font-heading text-lg font-semibold text-text">Telepon / WhatsApp</h3>
          <a href={`tel:${client.phoneForTel}`} class="mt-1 block text-primary-light font-medium transition-colors hover:text-primary">
            {client.phoneFormatted}
          </a>
          <a href={`https://wa.me/${client.phoneForTel.replace('+', '')}`} target="_blank" class="mt-2 inline-flex items-center gap-2 rounded-md bg-green-600 px-4 py-2 text-sm font-bold text-white hover:bg-green-700">
             Chat WhatsApp
          </a>
        </div>

        <div>
          <h3 class="font-heading text-lg font-semibold text-text">Email</h3>
          <a href={`mailto:${client.email}`} class="mt-1 block text-primary-light font-medium transition-colors hover:text-primary">
            {client.email}
          </a>
        </div>

        <div>
          <h3 class="font-heading text-lg font-semibold text-text">Area Layanan</h3>
          <p class="mt-1 text-text-muted leading-relaxed">
            {client.address.lineOne}, {client.address.lineTwo}
          </p>
        </div>
      </aside>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
