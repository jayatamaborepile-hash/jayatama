---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Banner from '../../components/Banner.astro';
import CTA from '../../components/CTA.astro';
import { brand } from '../../config/brand';
import { getWpPosts } from '../../data/wp-cms';

const posts = await getWpPosts();
---

<BaseLayout title="Blog" description={`Tips, panduan, dan berita terbaru dari ${brand.name}. Tetap terinformasi mengenai pondasi dan konstruksi.`}>
  <Header slot="header" />

  <Banner title="Blog" />

  <section class="py-section">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      {posts.length === 0 ? (
        <p class="text-center text-text-muted">Belum ada artikel. Silakan cek kembali nanti!</p>
      ) : (
        <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
          {posts.map((post) => {
            const formattedDate = post.date.toLocaleDateString('id-ID', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            });
            return (
              <article class="group flex flex-col overflow-hidden rounded-lg border border-border bg-background shadow-sm transition-shadow hover:shadow-md">
                {post.image && (
                   <img src={post.image} alt={post.title} class="aspect-video w-full object-cover" loading="lazy" />
                )}
                <div class="flex flex-1 flex-col p-6">
                  <div class="flex items-center gap-2 text-sm text-text-muted">
                    <time datetime={post.date.toISOString()}>{formattedDate}</time>
                  </div>
                  <h2 class="mt-3 font-heading text-h3 font-semibold text-text group-hover:text-primary transition-colors">
                    <a href={`/blog/${post.id}`} class="after:absolute after:inset-0 relative">
                      {post.title}
                    </a>
                  </h2>
                  <p class="mt-2 flex-1 text-sm leading-relaxed text-text-muted">
                    {post.description}
                  </p>
                  <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-primary">
                    Baca selengkapnya
                    <svg class="size-4 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </span>
                </div>
              </article>
            );
          })}
        </div>
      )}
    </div>
  </section>

  <CTA />

  <Footer slot="footer" />
</BaseLayout>
