---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Banner from '../components/Banner.astro';
import CTA from '../components/CTA.astro';
import { brand } from '../config/brand';
import { client } from '../data/client';
import { getWcProducts } from '../data/wc-cms';

const wcServices = await getWcProducts();

const icons = [
  '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />',
  '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />',
  '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />',
  '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />',
  '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />',
  '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />',
];
---

<BaseLayout
  title="Layanan"
  description={`Jelajahi berbagai layanan yang ditawarkan oleh ${brand.name}. Dari konsultasi hingga pengerjaan bore pile.`}
  schema={{
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Jasa Pondasi Bore Pile',
    provider: {
      '@type': 'LocalBusiness',
      name: brand.name,
    },
    areaServed: 'DKI Jakarta',
    hasOfferCatalog: {
      '@type': 'OfferCatalog',
      name: 'Layanan Jayatama Bore Pile',
      itemListElement: wcServices.map((s) => ({
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: s.name,
          description: s.short_description,
        }
      }))
    }
  }}
>
  <Header slot="header" />

  <Banner title="Layanan Kami" />

  <section class="py-section">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="mx-auto mb-10 max-w-2xl text-center lg:mb-14">
        <h2 class="font-heading text-h2 font-bold uppercase text-text">Apa yang kami tawarkan</h2>
        <p class="mt-3 text-text-muted leading-relaxed">
          Kami menyediakan solusi pondasi yang komprehensif untuk menjamin keamanan bangunan Anda.
        </p>
      </div>

      {wcServices.length === 0 ? (
        <div class="text-center py-10">
          <p class="text-text-muted italic">Belum ada layanan yang tersedia saat ini.</p>
          <p class="text-xs text-text-muted/50 mt-2">Pastikan konfigurasi WooCommerce di .env sudah benar dan produk sudah diterbitkan.</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
          {wcServices.map((service, i) => (
            <div class="group flex flex-col overflow-hidden rounded-xl border border-border bg-background shadow-sm transition-all hover:shadow-md">
              <!-- Product Image -->
              <div class="aspect-video overflow-hidden bg-surface relative">
                {service.image ? (
                  <img src={service.image} alt={service.name} class="size-full object-cover transition-transform duration-500 group-hover:scale-105" />
                ) : (
                  <div class="flex size-full items-center justify-center text-text-muted">
                    <svg class="size-12 opacity-20" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={icons[i % icons.length]} />
                  </div>
                )}
              </div>

              <div class="flex flex-1 flex-col p-6">
                <div class="flex items-center justify-between mb-2">
                  <h3 class="font-heading text-xl font-bold uppercase text-text group-hover:text-primary transition-colors">
                    <a href={`/layanan/${service.slug}`}>
                      {service.name}
                    </a>
                  </h3>
                </div>
                
                {service.price && (
                  <div class="mb-3 flex items-baseline gap-2">
                    {service.on_sale && service.regular_price && (
                      <span class="text-xs text-text-muted line-through">
                        {new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', minimumFractionDigits: 0 }).format(Number(service.regular_price))}
                      </span>
                    )}
                    <span class="text-lg font-bold text-primary">
                      {new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', minimumFractionDigits: 0 }).format(Number(service.price))}
                      <span class="text-xs font-normal text-text-muted">/ m</span>
                    </span>
                  </div>
                )}

                <p class="line-clamp-3 text-sm leading-relaxed text-text-muted">
                  {service.short_description}
                </p>
                
                <div class="mt-6 flex flex-wrap items-center gap-3 border-t border-border pt-6">
                  <a 
                    href={`/layanan/${service.slug}`} 
                    class="flex-1 rounded-md border border-primary px-4 py-2 text-center text-sm font-bold text-primary transition-colors hover:bg-primary/5"
                  >
                    Detail
                  </a>
                  <a 
                    href={`https://wa.me/${client.phoneForTel.replace(/\D/g, '')}?text=Halo Jayatama, saya ingin pesan layanan: ${service.name}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex-1 rounded-md bg-accent px-4 py-2 text-center text-sm font-bold text-accent-fg shadow-sm transition-opacity hover:opacity-90"
                  >
                    Pesan WA
                  </a>
                </div>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>

  <CTA />

  <Footer slot="footer" />
</BaseLayout>
